<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_collection_filter_sheet"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <View
            android:layout_width="46dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:alpha="0.22"
            android:background="@drawable/bg_black_button" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter Collection"
            android:textColor="@color/on_page"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:text="Sort, view, and narrow your collection faster."
            android:textColor="@color/on_page_variant"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_white_rounded"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvSortTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sort by"
                android:textColor="@color/on_page"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupSort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp"
                app:singleLine="false"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSortDefault"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Default"
                    android:textColor="@color/filter_chip_text"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/filter_chip_bg"
                    app:chipStrokeColor="@color/nav_brown"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSortAz"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name A-Z"
                    android:textColor="@color/filter_chip_text"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/filter_chip_bg"
                    app:chipStrokeColor="@color/nav_brown"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSortZa"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name Z-A"
                    android:textColor="@color/filter_chip_text"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/filter_chip_bg"
                    app:chipStrokeColor="@color/nav_brown"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSortNewest"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Newest"
                    android:textColor="@color/filter_chip_text"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/filter_chip_bg"
                    app:chipStrokeColor="@color/nav_brown"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSortOldest"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Oldest"
                    android:textColor="@color/filter_chip_text"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/filter_chip_bg"
                    app:chipStrokeColor="@color/nav_brown"
                    app:chipStrokeWidth="1dp" />
            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_white_rounded"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show"
                android:textColor="@color/on_page"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupShow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp"
                app:singleLine="false"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipShowAll"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All Cards"
                    android:textColor="@color/filter_chip_text"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/filter_chip_bg"
                    app:chipStrokeColor="@color/nav_brown"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipShowFavorites"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Favorites"
                    android:textColor="@color/filter_chip_text"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/filter_chip_bg"
                    app:chipStrokeColor="@color/nav_brown"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipShowRecent"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent Photos"
                    android:textColor="@color/filter_chip_text"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/filter_chip_bg"
                    app:chipStrokeColor="@color/nav_brown"
                    app:chipStrokeWidth="1dp" />
            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_white_rounded"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvRarityTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rarity"
                android:textColor="@color/on_page"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupRarity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp"
                app:singleLine="false"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRarityAll"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All"
                    android:textColor="@color/filter_chip_text"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/filter_chip_bg"
                    app:chipStrokeColor="@color/nav_brown"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRarityCommon"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Common"
                    android:textColor="@color/filter_chip_text"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/filter_chip_bg"
                    app:chipStrokeColor="@color/nav_brown"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRarityUncommon"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Uncommon"
                    android:textColor="@color/filter_chip_text"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/filter_chip_bg"
                    app:chipStrokeColor="@color/nav_brown"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRarityRare"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rare"
                    android:textColor="@color/filter_chip_text"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/filter_chip_bg"
                    app:chipStrokeColor="@color/nav_brown"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRarityEpic"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Epic"
                    android:textColor="@color/filter_chip_text"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/filter_chip_bg"
                    app:chipStrokeColor="@color/nav_brown"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRarityLegendary"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Legendary"
                    android:textColor="@color/filter_chip_text"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/filter_chip_bg"
                    app:chipStrokeColor="@color/nav_brown"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRarityMythic"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mythic"
                    android:textColor="@color/filter_chip_text"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/filter_chip_bg"
                    app:chipStrokeColor="@color/nav_brown"
                    app:chipStrokeWidth="1dp" />
            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnResetFilters"
                style="@style/BirdDex.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="Reset"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnApplyFilters"
                style="@style/BirdDex.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Apply"
                android:textAllCaps="false" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>