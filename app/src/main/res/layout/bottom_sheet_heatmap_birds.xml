<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="460dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSizeTop24"
        android:backgroundTint="?attr/colorSurface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="12dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:background="#D1D1D1" />

            <TextView
                android:id="@+id/tvSheetTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Birds in This Hotspot"
                android:textColor="?attr/colorOnSurface"
                android:textSize="22sp"
                android:letterSpacing="-0.01"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSheetSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Thumbs Up or Thumbs Down A Bird If You Have or Haven't Seen It"
                android:textSize="10sp"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/tvSheetStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_white_rounded"
                android:backgroundTint="#15000000"
                android:text="Hotspot status: Unverified"
                android:textColor="#FF8A00"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEmptyBirds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:text="No birds found for this hotspot."
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="15sp"
                android:visibility="gone" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:overScrollMode="ifContentScrolls">

                <LinearLayout
                    android:id="@+id/birdListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="16dp" />
            </androidx.core.widget.NestedScrollView>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
