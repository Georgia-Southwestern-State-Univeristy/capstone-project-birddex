<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="24dp"
    android:paddingBottom="8dp"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:gravity="center_horizontal">

    <ImageView
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/ic_camera"
        android:layout_marginBottom="12dp"
        android:contentDescription="@string/camera_tip_title"
        app:tint="@color/nav_brown"/>

    <TextView
        android:id="@+id/textViewTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/camera_tip_title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/nav_brown"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/textViewMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/camera_tip_message"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/on_page"
        android:gravity="start"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="16dp"
        android:paddingHorizontal="4dp"/>

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:alpha="0.1" />

    <CheckBox
        android:id="@+id/checkBoxDontShow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/dont_show_again"
        android:textColor="@color/nav_brown"
        android:buttonTint="@color/nav_brown"
        android:minHeight="40dp"
        android:textSize="14sp"/>

</LinearLayout>
