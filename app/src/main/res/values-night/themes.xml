<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.BirdDex" parent="Theme.Material3.Light.NoActionBar">
        <!-- Navigation (Primary) -->
        <item name="colorPrimary">@color/nav_brown</item>
        <item name="colorOnPrimary">@color/page_cream</item>

        <!-- Pages -->
        <item name="android:windowBackground">@color/page_cream</item>
        <item name="colorSurface">@color/page_cream</item>
        <item name="colorOnBackground">@color/on_page</item>
        <item name="colorOnSurface">@color/on_page</item>
        <item name="colorOnSurfaceVariant">@color/on_page_variant</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@color/nav_brown</item>
        <item name="android:navigationBarColor">@color/nav_brown</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
    </style>

    <style name="Theme.BirdDex.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/page_cream</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_screen_cold_start_icon</item>
        <item name="windowSplashScreenAnimationDuration">0</item>
        <item name="postSplashScreenTheme">@style/Theme.BirdDex</item>
    </style>
</resources>