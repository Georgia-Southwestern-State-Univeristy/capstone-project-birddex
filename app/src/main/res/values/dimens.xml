<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- core-splashscreen draws a circular mask via a thick stroke; 0dp removes that ring. -->
    <dimen name="splashscreen_icon_mask_stroke_no_background">0dp</dimen>
    <dimen name="splashscreen_icon_mask_stroke_with_background">0dp</dimen>

    <!-- Full-screen card viewer: max width so the card reads as a tall portrait like the collection tile -->
    <dimen name="view_bird_card_max_width">320dp</dimen>
    <!-- Collection / favorites grid thumbnail height -->
    <dimen name="collection_card_image_height">112dp</dimen>
    <!-- Auth / form cards: tighter margins on very narrow phones -->
    <dimen name="auth_card_horizontal_margin">16dp</dimen>
    <!-- Forum post image preview -->
    <dimen name="forum_post_image_height">200dp</dimen>
</resources>
