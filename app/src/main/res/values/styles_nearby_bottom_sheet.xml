<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="BirdDexNearbyBottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BirdDexNearbyBottomSheet</item>
    </style>

    <style name="BirdDexNearbyBottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
        <item name="shapeAppearance">@style/BirdDexNearbyBottomSheetShapeAppearance</item>
    </style>

    <style name="BirdDexNearbyBottomSheetShapeAppearance" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamilyTopLeft">rounded</item>
        <item name="cornerFamilyTopRight">rounded</item>
        <item name="cornerSizeTopLeft">28dp</item>
        <item name="cornerSizeTopRight">28dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>
