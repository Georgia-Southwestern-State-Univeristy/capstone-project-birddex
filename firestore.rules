rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn();
      // Allow only the owner to update their profile (bio, pfp, etc.)
      allow update: if isOwner(userId);
      // Deny direct creation/deletion; handled by Cloud Functions
      allow create, delete: if false;

      // --- Following Sub-collection ---
      match /following/{followedId} {
        allow read: if isSignedIn();
        allow write: if false;
      }

      // --- Followers Sub-collection ---
      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow write: if false;
      }

      // --- Collection Slots ---
      match /collectionSlot/{slotId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      // --- Bird Images ---
      match /userBirdImage/{imageId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      // --- Settings (Cooldowns, etc.) ---
      match /settings/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Forum Collection ---
        match /forumThreads/{postId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
          allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
          // Allow non-owners to update stats and view tracking
          allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'likedBy', 'viewCount', 'viewedBy', 'commentCount']);

          match /comments/{commentId} {
            allow read: if isSignedIn();
            allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
            // Allow deletion if the user owns the comment OR if they own the parent thread
            allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/forumThreads/$(postId)).data.userId == request.auth.uid);
            // Allow non-owners to update like status
            allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'likedBy']));
          }
        }

    // --- Backlog Collection for Deletions ---
    match /deletedforum_backlog/{docId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    // --- Reports Collection ---
    match /reports/{reportId} {
      allow read: if false;
      allow create: if isSignedIn();
    }

    // --- Birds & Facts ---
    match /birds/{birdId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /birdFacts/{birdId} {
      allow read: if isSignedIn();
      allow write: if false;
      match /hunterFacts/{factId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // --- Global Collections ---
    match /userBirds/{sightingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
    match /userBirdSightings/{sightingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
    match /identifications/{idId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }
    match /locations/{locId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /hunterSightings/{sightingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
  }
}
