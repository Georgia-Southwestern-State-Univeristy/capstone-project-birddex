rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isOwnerOfResource() {
      return request.auth != null && resource.data.userId == request.auth.uid;
    }

    function incomingDataOwned() {
      return request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    function onlySessionFieldUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['currentSessionId']) &&
        request.resource.data.currentSessionId is string &&
        request.resource.data.currentSessionId.size() > 0;
    }

    function isValidRarity(rarity) {
      return rarity == 'common' ||
        rarity == 'uncommon' ||
        rarity == 'rare' ||
        rarity == 'epic' ||
        rarity == 'legendary';
    }

    // New collection slots created from the client must start as common.
    // If you later move slot creation to Cloud Functions only, change the
    // collectionSlot create rule to false.
    function validClientCollectionSlotCreate() {
      return request.resource.data.keys().hasAll(['rarity']) &&
        isValidRarity(request.resource.data.rarity) &&
        request.resource.data.rarity == 'common';
    }

    // Client must never be able to directly change rarity or server-owned
    // upgrade bookkeeping fields.
    function onlyClientCollectionSlotFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny([
          'rarity',
          'pointsSpent',
          'upgradeCost',
          'nextUpgradeCost',
          'lastUpgradeAt',
          'upgradedAt',
          'rarityUpdatedAt',
          'upgradeRequestedAt',
          'upgradeCompletedAt',
          'upgradeVersion'
        ]);
    }

    // Fields that only Cloud Functions should ever write.
    // Username, bio, and profilePictureUrl are now backend-moderated too.
    // totalPoints is also backend-owned so users cannot grant themselves points
    // or fake card-upgrade affordability.
    function onlyClientProfileFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny([
          'username',
          'bio',
          'profilePictureUrl',

          'totalPoints',
          'totalBirds',
          'duplicateBirds',

          'openAiRequestsRemaining',
          'openAiCooldownResetTimestamp',
          'pfpChangesToday',
          'pfpCooldownResetTimestamp',

          'followerCount',
          'followingCount',

          'profileSyncStatus',
          'profileSyncStartedAt',
          'profileSyncCompletedAt',

          'currentSessionId'
        ]);
    }

    // Client-side forum thread engagement still allowed for now.
    // If likes/views are later moved to Cloud Functions too, set forum thread updates to false.
    function onlyClientForumThreadEngagementUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['likeCount', 'likedBy', 'viewCount', 'viewedBy']);
    }

    // Client-side comment likes still allowed for now.
    // If comment likes are later moved to Cloud Functions too, set comment updates to false.
    function onlyClientCommentLikeUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['likedBy']);
    }

    // Client can still create/update their own userBirds docs, but cannot set or edit
    // backend-owned reward/attribution fields.
    function validClientUserBirdCreate() {
      return !request.resource.data.keys().hasAny([
        'pointsAwarded',
        'pointsAttributed',
        'attributionStatus',
        'attributedAt',
        'rewardGranted',
        'rewardGrantedAt'
      ]);
    }

    function onlyClientUserBirdFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny([
          'pointsAwarded',
          'pointsAttributed',
          'attributionStatus',
          'attributedAt',
          'rewardGranted',
          'rewardGrantedAt'
        ]);
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Any signed-in user can read public profiles
      allow read: if isSignedIn();

      // Owner can update only non-CF-managed profile fields,
      // or update currentSessionId only.
      allow update: if isOwner(userId) && (
        onlyClientProfileFields() ||
        onlySessionFieldUpdate()
      );

      // Creation/deletion handled by Cloud Functions only
      allow create, delete: if false;

      // --- Following Sub-collection ---
      match /following/{followedId} {
        allow read: if isSignedIn();
        allow write: if false; // Cloud Functions only
      }

      // --- Followers Sub-collection ---
      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow write: if false; // Cloud Functions only
      }

      // --- Collection Slots ---
      match /collectionSlot/{slotId} {
        allow read: if isSignedIn();

        // Client may create a new slot only if it starts as common.
        allow create: if isOwner(userId) && validClientCollectionSlotCreate();

        // Client may update normal card fields, but never rarity or server-owned upgrade fields.
        allow update: if isOwner(userId) && onlyClientCollectionSlotFields();

        // Keep delete behavior the same as before.
        allow delete: if isOwner(userId);
      }

      // --- Bird Images ---
      match /userBirdImage/{imageId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      // --- Collection Metadata (counter, etc.) ---
      match /collectionMeta/{docId} {
        allow read, write: if isOwner(userId);
      }

      // --- Settings (CF-managed: cooldowns, post limits, PFP limits) ---
      match /settings/{docId} {
        allow read: if isOwner(userId);
        allow write: if false; // Cloud Functions only
      }

      // --- Saved Posts ---
      // Save/unsave goes through Cloud Functions.
      // Client can read their own saved posts feed.
      match /savedPosts/{threadId} {
        allow read: if isOwner(userId);
        allow write: if false; // Cloud Functions only
      }
    }

    // --- Usernames (Global Registry for Uniqueness) ---
    match /usernames/{username} {
      allow read: if true;
      allow write: if false; // Cloud Functions (initializeUser) only
    }

    // --- Forum Threads ---
    match /forumThreads/{postId} {
      allow read: if isSignedIn();

      // Post create/edit/delete now go through Cloud Functions only.
      allow create: if false;
      allow delete: if false;

      // Keep only engagement fields client-writable for now.
      allow update: if isSignedIn() && onlyClientForumThreadEngagementUpdate();

      match /comments/{commentId} {
        allow read: if isSignedIn();

        // Comment/reply create/delete now go through Cloud Functions only.
        allow create: if false;
        allow delete: if false;

        // Keep only comment-like field client-writable for now.
        allow update: if isSignedIn() && onlyClientCommentLikeUpdate();
      }
    }

    // --- Backlog Collection for Deletions ---
    match /deletedforum_backlog/{docId} {
      allow read, write: if false; // Cloud Functions only
    }

    // --- Reports Collection ---
    match /reports/{reportId} {
      allow read: if false; // Admin only via Cloud Functions
      allow create: if isSignedIn() && incomingDataOwned();
    }

    // --- Birds & Facts (read-only reference data) ---
    match /birds/{birdId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /birdFacts/{birdId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /hunterFacts/{factId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }


		 //-- bird images--
		match /nuthatch_images/{docId} {
  		allow read: if request.auth != null;
		}

		match /inaturalist_images/{docId} {
  		allow read: if request.auth != null;
		}
    // --- Upgrade Card Data (read-only reference data) ---
    match /upgradeCardData/{docId} {
      allow read: if isSignedIn();
      allow write: if false; // Cloud Functions / admin only
    }

    // --- User Bird Sightings / User Birds ---
    match /userBirds/{sightingId} {
      allow read: if isSignedIn() && isOwnerOfResource();

      // Client may create their own userBirds records, but cannot attach
      // reward/attribution fields directly.
      allow create: if isSignedIn() &&
        incomingDataOwned() &&
        validClientUserBirdCreate();

      // Client may update normal fields, but not backend-owned reward/attribution fields.
      allow update: if isSignedIn() &&
        isOwnerOfResource() &&
        onlyClientUserBirdFields();

      allow delete: if isSignedIn() && isOwnerOfResource();
    }

    match /userBirdSightings/{sightingId} {
      allow read: if isSignedIn();
      allow write: if false; // Cloud Functions only
    }

    // --- Identifications (Internal logging only) ---
    match /identifications/{idId} {
      allow read, write: if false; // Cloud Functions only
    }

    // --- Locations ---
    match /locations/{locId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();

      // Allow updates ONLY if the coordinates haven't changed.
      allow update: if isSignedIn() &&
        request.resource.data.latitude == resource.data.latitude &&
        request.resource.data.longitude == resource.data.longitude;

      allow delete: if false;
    }

    // --- Hunter Sightings ---
    match /hunterSightings/{sightingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incomingDataOwned();
      allow update, delete: if isSignedIn() && isOwnerOfResource();
    }

    // --- eBird API Sightings (read-only, written by Cloud Functions) ---
    match /eBirdApiSightings/{sightingId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // --- Idempotency & Scheduler Locks ---
    match /processedEvents/{eventId} {
      allow read, write: if false; // Cloud Functions only
    }

    match /processedAIEvents/{eventId} {
      allow read, write: if false; // Cloud Functions only
    }

    match /schedulerLocks/{lockId} {
      allow read, write: if false; // Cloud Functions only
    }

    // --- Archived / Deleted Accounts ---
    match /usersdeletedAccounts/{userId} {
      allow read, write: if false; // Cloud Functions only
    }
  }
}