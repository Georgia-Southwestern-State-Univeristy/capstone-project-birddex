rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isOwnerOfResource() {
      return request.auth != null && resource.data.userId == request.auth.uid;
    }

    function incomingDataOwned() {
      return request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Any signed-in user can read public profiles
      allow read: if isSignedIn();
      // Only owner can update their own profile
      allow update: if isOwner(userId);
      // Creation/deletion handled by Cloud Functions only
      allow create, delete: if false;

      // --- Following Sub-collection ---
      match /following/{followedId} {
        allow read: if isSignedIn();
        allow write: if false; // Cloud Functions only
      }

      // --- Followers Sub-collection ---
      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow write: if false; // Cloud Functions only
      }

      // --- Collection Slots ---
      match /collectionSlot/{slotId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      // --- Bird Images ---
      match /userBirdImage/{imageId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      // --- Settings (private to owner only) ---
      match /settings/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Forum Collection ---
    match /forumThreads/{postId} {
      allow read: if isSignedIn();

      // Only create if the userId field matches the requester
      allow create: if isSignedIn() && incomingDataOwned();

      // Owner can update/delete their thread
      // Any signed-in user can update ONLY the stat fields
      allow update: if isSignedIn() && (
        isOwnerOfResource() ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likeCount', 'likedBy', 'viewCount', 'viewedBy', 'commentCount'])
      );
      allow delete: if isSignedIn() && isOwnerOfResource();

      match /comments/{commentId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn() && incomingDataOwned();

        // Owner of comment or owner of parent thread can delete
        allow delete: if isSignedIn() && (
          isOwnerOfResource() ||
          get(/databases/$(database)/documents/forumThreads/$(postId)).data.userId == request.auth.uid
        );

        // Comment owner can update freely; others can only update like fields
        allow update: if isSignedIn() && (
          isOwnerOfResource() ||
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likeCount', 'likedBy'])
        );
      }
    }

    // --- Backlog Collection for Deletions ---
    match /deletedforum_backlog/{docId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    // --- Reports Collection ---
    match /reports/{reportId} {
      allow read: if false; // Admin only via Cloud Functions
      allow create: if isSignedIn() && incomingDataOwned();
    }

    // --- Birds & Facts (read-only reference data) ---
    match /birds/{birdId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /birdFacts/{birdId} {
      allow read: if isSignedIn();
      allow write: if false;
      match /hunterFacts/{factId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // --- User Bird Sightings (private to owner) ---
    match /userBirds/{sightingId} {
      allow read: if isSignedIn() && isOwnerOfResource();
      allow create: if isSignedIn() && incomingDataOwned();
      allow update, delete: if isSignedIn() && isOwnerOfResource();
    }
    match /userBirdSightings/{sightingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incomingDataOwned();
      allow update, delete: if isSignedIn() && isOwnerOfResource();
    }

    // --- Identifications ---
    match /identifications/{idId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incomingDataOwned();
      allow update, delete: if isSignedIn() && isOwnerOfResource();
    }

    // --- Locations ---
    match /locations/{locId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incomingDataOwned();
      // Only the creator can update/delete their location
      allow update, delete: if isSignedIn() && isOwnerOfResource();
    }

    // --- Hunter Sightings ---
    match /hunterSightings/{sightingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incomingDataOwned();
      allow update, delete: if isSignedIn() && isOwnerOfResource();
    }

    // --- eBird API Sightings (read-only, written by Cloud Functions) ---
    match /eBirdApiSightings/{sightingId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
