rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Rule for user-uploaded identification history images
    match /identificationImages/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Rule for user-uploaded original images (Legacy)
    match /user_images/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rule for user collection images
    match /userCollectionImages/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rule for profile pictures - simplified to debug 403
    match /profile_pictures/{imageName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Rule for forum post images
    match /forum_post_images/{imageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      // Allow deletion only if the user is authenticated (handled by app logic with backlog)
      allow delete: if request.auth != null;
    }

    // Rule for ARCHIVED forum post images
    match /archive/forum_post_images/{userId}/{imageId} {
      // Only admins should ideally read this, but for app logic we allow write/create
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Rule for ebird_birds_export
    match /ebirdIds/{fileName} {
      allow read: if request.auth != null && request.auth.token.email == 'dominique.solomon21@gmail.com';
      allow write: if request.auth != null && request.auth.token.email == 'dominique.solomon21@gmail.com';
    }

    // Rule for user-generated collection cards
    match /bird_cards/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}